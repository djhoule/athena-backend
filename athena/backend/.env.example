# ─────────────────────────────────────────────────────────────────────────────
# ATHENA AI — Backend Environment Variables
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (REQUIRED) ───────────────────────────────────────────────────────
# Supabase connection string (PostgreSQL + asyncpg driver)
# Format: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# ── Auth (REQUIRED) ───────────────────────────────────────────────────────────
# Random secret key used to sign JWT tokens — minimum 32 characters
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# ── Market Data APIs (OPTIONAL) ───────────────────────────────────────────────
# Alpha Vantage — used for fundamental data fallback (free: 25 req/day)
# Get key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=

# Polygon.io — not currently used but wired up in config (free tier available)
# Get key at: https://polygon.io/
POLYGON_API_KEY=

# Binance — no API key needed for public OHLCV/crypto data (used by data_fetcher)
BINANCE_API_KEY=

# ── News / Sentiment (OPTIONAL) ───────────────────────────────────────────────
# NewsAPI — used for sentiment scoring (free: 100 req/day)
# Get key at: https://newsapi.org/
NEWS_API_KEY=

# ── Notifications (OPTIONAL) ──────────────────────────────────────────────────
# Expo push notification access token (for mobile push alerts)
# Get at: https://expo.dev/accounts/YOUR_ACCOUNT/settings/access-tokens
EXPO_ACCESS_TOKEN=

# Discord webhook URL for Grade A trade alerts in your server
# Create at: Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=
